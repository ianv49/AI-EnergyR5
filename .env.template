# AI-EnergyR5 Environment Configuration Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env is in .gitignore - Never commit it with real secrets!

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=energy_data

# Optional: PostgreSQL connection string (alternative to individual settings)
# DATABASE_URL=postgresql://user:password@localhost:5432/energy_data

# ==========================================
# API Keys & Credentials
# ==========================================

# Open-Meteo (Free, no key required)
OPEN_METEO_API_URL=https://api.open-meteo.com/v1

# NASA POWER API (Free)
NASA_API_KEY=your_nasa_api_key
NASA_API_URL=https://power.larc.nasa.gov/api/v1

# Meteostat (Free with RapidAPI optional)
METEOSTAT_API_KEY=your_meteostat_api_key
METEOSTAT_RAPIDAPI_KEY=your_rapidapi_key

# Solcast (Requires API key)
SOLCAST_API_KEY=your_solcast_api_key
SOLCAST_API_URL=https://api.solcast.com.au

# OpenWeather (Requires API key)
OPENWEATHER_API_KEY=your_openweather_api_key

# Tomorrow.io (Requires API key)
TOMORROWIO_API_KEY=your_tomorrowio_api_key

# PVOutput (Optional, requires API key)
PVOUTPUT_API_KEY=your_pvoutput_api_key
PVOUTPUT_SYSTEM_ID=your_system_id

# ==========================================
# MQTT Configuration (for IoT sensor streaming)
# ==========================================
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_password
MQTT_TOPIC_PREFIX=energy/sensors/

# ==========================================
# Flask Web Configuration
# ==========================================
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_SECRET_KEY=your_secret_key_for_session_management

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==========================================
# Feature Flags
# ==========================================
ENABLE_SCHEDULER=True
ENABLE_API_CACHE=True
CACHE_TTL_HOURS=24

# ==========================================
# System Configuration
# ==========================================
TIMEZONE=UTC
LOCATION_LAT=51.5074
LOCATION_LON=-0.1278
LOCATION_NAME=London
